APP_NAME='Farmville Classic'
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=https://yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# Enable Maintenance Mode
MAINTENANCE_MODE=false

# PHP_CLI_SERVER_WORKERS=4

# Enable Discord Status
DISCORD_STATUS_ENABLED=false
DISCORD_STATUS_WEBHOOK=
DISCORD_STATUS_CHANNEL_ID=
DISCORD_STATUS_SERVER_LOCATION="Singapore" 

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# FarmVille Flash service logging (true/false) 
FARMVILLE_LOG_ENABLED=true

DB_CONNECTION=mysql
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Redis Configuration (Not implemented yet)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration (Not implemented yet)
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS Configuration (Not implemented yet)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Backblaze B2 Configuration (Fully implemented)
B2_ACCESS_KEY_ID=
B2_SECRET_ACCESS_KEY=
B2_REGION=us-east-005
B2_BUCKET=your-bucket-name
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_URL=https://your-bucket-name.s3.us-east-005.backblazeb2.com

# Chat settings for Reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=play.website.com
REVERB_PORT=443
REVERB_SCHEME=https
# set to blank 
REVERB_SERVER_PATH= 

VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=play.website.com
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
VITE_REVERB_PATH=/ws

BROADCAST_DRIVER=reverb
BROADCAST_CONNECTION=reverb